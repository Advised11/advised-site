---
const CALENDLY = 'https://calendly.com/contact-advised-seo/30min';
const sectors = [
  { href: '/secteur-saas', code: 'SaaS', t: 'SaaS B2B', s: 'Pipeline organique & présence IA' },
  { href: '/secteur-tpe-pme', code: 'PME', t: 'TPE / PME', s: 'Des leads réguliers, sans agence' },
  { href: '/secteur-ecommerce', code: 'E-c', t: 'E-commerce', s: 'Fiches & catégories qui vendent' },
  { href: '/secteur-local', code: 'Loc', t: 'Local & multi-sites', s: 'Store locator & SEO local' },
  { href: '/secteur-media', code: 'Méd', t: 'Média & éditorial', s: 'Trafic de contenu durable' },
];
---

<header class="nav">
  <div class="wrap nav-inner">
    <a class="logo" href="/"><img class="mark-img" src="/logo-light.png" alt="" /> Advised</a>
    <nav class="nav-links" id="navlinks">
      <a href="/services">Services</a>
      <div class="has-dd">
        <button class="dd-toggle" type="button" aria-haspopup="true">Secteurs <span class="chev"></span></button>
        <div class="dd-menu">
          {sectors.map((x) => (
            <a href={x.href}><span class="di">{x.code}</span><span><span class="dt">{x.t}</span><span class="ds">{x.s}</span></span></a>
          ))}
        </div>
      </div>
      <a href="/#methode">Méthode</a>
      <a href="/a-propos">À propos</a>
      <a href="/contact">Contact</a>
    </nav>
    <div class="nav-cta">
      <a class="btn btn-ghost" href={CALENDLY} target="_blank" rel="noopener">Réserver 30 min</a>
      <a class="btn btn-primary" href="/pre-audit">Pré-audit gratuit <span class="arr">→</span></a>
    </div>
    <button class="nav-burger" aria-label="Menu" id="burger"><span></span><span></span><span></span></button>
  </div>
</header>
